<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Remove invalid permission CONFIGURATION_CHANGED_ACTION -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
        tools:targetApi="34" />

    <application>

        <activity
            android:name=".activity.IRMonitorActivity"
            android:launchMode="singleTop"
            android:screenOrientation="userPortrait" />
        
        <activity
            android:name=".activity.IRLogMPChartActivity"
            android:launchMode="singleTop"
            android:screenOrientation="userPortrait" />

        <activity
            android:name=".activity.IRConfigActivity"
            android:launchMode="singleTop"
            android:screenOrientation="userPortrait" />
        <activity android:name=".activity.TestRecordActivity" />
        <activity
            android:name=".report.activity.ReportCreateFirstActivity"
            android:screenOrientation="userPortrait" />
        <activity
            android:name=".report.activity.ReportCreateSecondActivity"
            android:screenOrientation="userPortrait" />
        <activity
            android:name=".report.activity.ReportDetailActivity"
            android:screenOrientation="userPortrait" />
        <activity
            android:name=".report.activity.ReportPreviewFirstActivity"
            android:screenOrientation="userPortrait" />
        <activity
            android:name=".report.activity.ReportPreviewSecondActivity"
            android:screenOrientation="userPortrait" />
        <activity
            android:name=".report.activity.PDFListActivity"
            android:screenOrientation="userPortrait" />

        <activity
            android:name=".activity.IRCorrectionThreeActivity"
            android:screenOrientation="userPortrait" />

        <activity
            android:name=".activity.ReportPreviewActivity"
            android:screenOrientation="userPortrait" />

        <!-- Activities from thermal module -->

        <!-- Activities from thermal-lite module -->
        <activity android:name=".lite.activity.IRMonitorLiteActivity" />
        <activity android:name=".lite.activity.IRMonitorChartLiteActivity" />
        <activity android:name=".lite.activity.IRCorrectionLiteThreeActivity" />
        <activity android:name=".lite.activity.IRCorrectionLiteFourActivity" />
        <activity
            android:name=".lite.activity.ImagePickIRLiteActivity"
            android:screenOrientation="portrait" />
        <activity
            android:name=".lite.activity.IRThermalLiteActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="true"
            android:launchMode="singleTask"
            android:maxAspectRatio="2.4"
            android:requestLegacyExternalStorage="true"
            android:screenOrientation="userPortrait"
            android:windowSoftInputMode="adjustPan" />

        <!-- Missing base activities -->
        
        <activity
            android:name=".activity.BaseIRPlushActivity"
            android:screenOrientation="userPortrait" />
        <activity
            android:name=".activity.ChartActivity"
            android:screenOrientation="userPortrait" />
        <activity
            android:name=".lite.ui.activity.IrDisplayActivity"
            android:screenOrientation="userPortrait" />

        <!-- Jetpack Compose Activities - Thermal Module -->
        <activity
            android:name=".activity.ThermalCameraComposeActivity"
            android:exported="false"
            android:label="Thermal Camera (Compose)"
            android:screenOrientation="userPortrait" />

        <!-- New Compose Activities for Phase 5 Thermal Modernization -->
        <activity
            android:name=".activity.IRMainComposeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.IRCamera" />

        <activity
            android:name=".activity.ThermalGalleryComposeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.IRCamera" />

        <activity
            android:name=".activity.ThermalReportComposeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.IRCamera" />

        <!-- New Component Module Compose Activities -->
        <activity
            android:name=".lite.activity.IRThermalLiteComposeActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTask"
            android:maxAspectRatio="2.4"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.IRCamera" />

        <activity
            android:name=".lite.activity.IRMonitorLiteComposeActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.IRCamera" />

        <activity
            android:name=".lite.activity.ImagePickIRLiteComposeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.IRCamera" />

        <activity
            android:name=".report.activity.ReportCreateComposeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.IRCamera" />
    </application>

</manifest>
