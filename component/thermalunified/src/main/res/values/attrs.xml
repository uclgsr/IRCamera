<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="TemperatureBaseView">
        <attr name="maxCount" format="integer" />
        <attr name="markerColor" format="color" />
    </declare-styleable>

    <!-- ReportIRInputView styleable -->
    <declare-styleable name="ReportIRInputView">
        <attr name="type" format="string" />
        <attr name="index" format="integer" />
    </declare-styleable>

    <!-- LinearCompassView styleable -->
    <declare-styleable name="LinearCompassView">
        <attr name="lineColor" format="color" />
        <attr name="textColor" format="color" />
        <attr name="backgroundColor" format="color" />
        <attr name="shortLineColor" format="color" />
        <attr name="longLineColor" format="color" />
        <attr name="positionColor" format="color" />
        <attr name="compassMarkerColor" format="color" />
        <attr name="shortLineSize" format="dimension" />
        <attr name="longLineSize" format="dimension" />
        <attr name="positionSize" format="dimension" />
        <attr name="markerSize" format="dimension" />
    </declare-styleable>

</resources>