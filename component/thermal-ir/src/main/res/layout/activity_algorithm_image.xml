<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/schemas/android.com/apk/res/android"
    android:gravity="center"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:gravity="center"
        android:id="@+id/tvAlgorithmTitle"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:paddingBottom="16dp"
        android:text="Algorithm Image Processing"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/img"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:scaleType="centerInside" />

    <TextView
        android:gravity="center"
        android:id="@+id/tvAlgorithmInfo"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:paddingTop="16dp"
        android:text="Image algorithm processing results will be displayed above"
        android:textSize="14sp" />

</LinearLayout>
