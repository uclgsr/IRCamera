<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Legacy Bluetooth permissions for API < 31 -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- New Bluetooth permissions for API >= 31 -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADVERTISE"
        tools:targetApi="31" />


    <!-- Location permissions needed for Bluetooth scanning on older APIs and address detection -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Storage permissions for legacy external storage -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />


    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />


    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />


    <!-- Notification permission for API >= 33 -->
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />


    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />


    <uses-permission android:name="android.permission.CAMERA" />


    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.camera.front"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.flash"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />

    <!-- Media permissions for API >= 33 -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        tools:targetApi="33" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        tools:targetApi="33" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
        tools:targetApi="34" />

    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.usb.accessory"
        android:required="false" />

    <application
        android:name="mpdc4gsr.core.App"
        android:allowBackup="true"
        android:allowNativeHeapPointerTagging="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="${app_name}"
        android:requestLegacyExternalStorage="true"
        android:resizeableActivity="false"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true"
        tools:replace="android:hardwareAccelerated,android:label">

        <uses-native-library
            android:name="libOpenCL.so"
            android:required="false" />
        <uses-native-library
            android:name="libcutils.so"
            android:required="false" />

        <meta-data
            android:name="app_name"
            android:value="${app_name}" />


        <meta-data
            android:name="ScopedStorage"
            android:value="true" />

        <activity
            android:name="mpdc4gsr.activities.IRGalleryEditActivity"
            android:launchMode="singleTop"
            android:screenOrientation="userPortrait"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".BlankDevActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="true"
            android:theme="@style/Blank">

            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/ir_device_filter" />
        </activity>


        <receiver
            android:name="mpdc4gsr.sensors.thermal.ThermalUsbReceiver"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
                <action android:name="android.hardware.usb.action.USB_DEVICE_DETACHED" />
                <action android:name="mpdc4gsr.USB_PERMISSION" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/ir_device_filter" />
        </receiver>

        <activity
            android:name="mpdc4gsr.activities.MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="mpdc4gsr.activities.ShimmerMvpActivity"
            android:exported="true"
            android:label="Shimmer GSR MVP"
            android:theme="@style/AppTheme" />


        <activity
            android:name="mpdc4gsr.activities.UnifiedSensorActivity"
            android:exported="true"
            android:label="Unified Sensor Platform"
            android:theme="@style/AppTheme" />

        <activity android:name="mpdc4gsr.activities.ClauseActivity" />

        <activity
            android:name="mpdc4gsr.activities.NetworkClientTestActivity"
            android:exported="false"
            android:label="Network Client Test"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.activities.SimpleNetworkTestActivity"
            android:exported="false"
            android:label="Simple Network Test"
            android:theme="@style/AppTheme" />

        <activity android:name="mpdc4gsr.activities.PdfActivity" />
        <activity android:name="mpdc4gsr.activities.PolicyActivity" />
        <activity android:name="mpdc4gsr.activities.VersionActivity" />
        <activity android:name="mpdc4gsr.activities.DeviceTypeActivity" />
        <activity android:name="mpdc4gsr.activities.MoreHelpActivity" />
        <activity android:name="mpdc4gsr.activities.WebViewActivity" />

        <activity
            android:name="mpdc4gsr.activities.NetworkConfigActivity"
            android:exported="false"
            android:label="Network Configuration"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.MultiModalRecordingActivity"
            android:exported="false" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRQuickRecordingActivity"
            android:exported="false"
            android:label="@string/gsr_quick_access" />

        <activity
            android:name="mpdc4gsr.activities.FaultTolerantRecordingActivity"
            android:exported="false"
            android:label="@string/enhanced_recording_label" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionManagerActivity"
            android:exported="false"
            android:label="Session Manager" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.ResearchTemplateActivity"
            android:exported="false"
            android:label="Research Templates" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionDetailActivity"
            android:exported="false"
            android:label="Session Details" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionExportActivity"
            android:exported="false"
            android:label="Export Session" />

        <activity
            android:name="mpdc4gsr.sensors.HubSpokeIntegrationActivity"
            android:exported="false"
            android:label="Hub-Spoke Recording" />

        <activity
            android:name="mpdc4gsr.network.DevicePairingActivity"
            android:exported="false"
            android:label="Device Pairing" />

        <activity
            android:name="mpdc4gsr.permissions.PermissionRequestActivity"
            android:exported="false"
            android:label="Enhanced Permission System Test" />

        <!-- Additional GSR Activities -->
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRVideoPlayerActivity"
            android:exported="false"
            android:label="GSR Video Player" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRPlotActivity"
            android:exported="false"
            android:label="GSR Plot Viewer" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRDataViewActivity"
            android:exported="false"
            android:label="GSR Data Viewer" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRSettingsActivity"
            android:exported="false"
            android:label="GSR Settings" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRRawImageViewActivity"
            android:exported="false"
            android:label="GSR Raw Image Viewer" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRGalleryActivity"
            android:exported="false"
            android:label="GSR Gallery" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRDeviceManagementActivity"
            android:exported="false"
            android:label="GSR Device Management" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.ShimmerConfigActivity"
            android:exported="false"
            android:label="Shimmer Configuration" />


        <!-- Test Activities -->
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRBenchTestActivity"
            android:exported="false"
            android:label="GSR Benchmark Test" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRDataIntegrityTestActivity"
            android:exported="false"
            android:label="GSR Data Integrity Test" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRReconnectionTestActivity"
            android:exported="false"
            android:label="GSR Reconnection Test" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.ParallelRecordingTestActivity"
            android:exported="false"
            android:label="Parallel Recording Test" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionLifecycleTestActivity"
            android:exported="false"
            android:label="Session Lifecycle Test" />

        <!-- Camera Activities -->
        <activity
            android:name="mpdc4gsr.camera.integration.DualModeCameraActivity"
            android:exported="false"
            android:label="Dual Mode Camera" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.RawCaptureTestActivity"
            android:exported="false"
            android:label="Raw Capture Test" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.RgbCameraTestActivity"
            android:exported="false"
            android:label="RGB Camera Test" />

        <!-- Session and Synchronization Activities -->
        <activity
            android:name="mpdc4gsr.sensors.gsr.CompleteSessionTrialActivity"
            android:exported="false"
            android:label="Complete Session Trial" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.CrossModalSyncTestActivity"
            android:exported="false"
            android:label="Cross Modal Sync Test" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.SynchronizationTestActivity"
            android:exported="false"
            android:label="Synchronization Test" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.TimeSynchronizationTestActivity"
            android:exported="false"
            android:label="Time Synchronization Test" />

        <!-- BLE and Permission Activities -->
        <activity
            android:name="mpdc4gsr.sensors.gsr.BLEIntegrationTestActivity"
            android:exported="false"
            android:label="BLE Integration Test" />


        <!-- Simplified Main Activity -->
        <activity
            android:name="mpdc4gsr.activities.SimplifiedMainActivity"
            android:exported="false"
            android:label="Simplified Main"
            android:theme="@style/AppTheme" />

        <!-- Jetpack Compose Activities - Task Implementation -->
        <activity
            android:name="mpdc4gsr.activities.MainActivityCompose"
            android:exported="false"
            android:label="Main Dashboard (Compose)"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.activities.SensorDashboardComposeActivity"
            android:exported="false"
            android:label="Sensor Dashboard (Compose)"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.activities.SettingsComposeActivity"
            android:exported="false"
            android:label="Settings (Compose)"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.activities.ComposeDemoActivity"
            android:exported="true"
            android:label="Compose Infrastructure Demo"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.activities.FullMigrationDemoActivity"
            android:exported="true"
            android:label="Full Migration Demo"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name="mpdc4gsr.activities.ComposeMigrationLauncherActivity"
            android:exported="true"
            android:label="Compose Migration Launcher"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Enhanced Compose Activities - Updated with dev branch integration -->
        <activity
            android:name="mpdc4gsr.activities.MainActivityComposeEnhanced"
            android:exported="true"
            android:label="Enhanced Main Dashboard"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.activities.SensorDashboardComposeEnhanced"
            android:exported="true"
            android:label="Enhanced Sensor Dashboard"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <service
            android:name="mpdc4gsr.core.RecordingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="camera|microphone|mediaProjection" />

        <service
            android:name="mpdc4gsr.core.BackgroundDeviceScanningService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true"
            tools:replace="android:authorities">

            <meta-data
                android:name="androidx.core.content.FileProvider.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths"
                tools:replace="android:resource" />
        </provider>
    </application>

</manifest>