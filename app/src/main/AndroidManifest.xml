<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Bluetooth (API ≤ 30 use legacy; API 31+ use new runtime perms) -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30"/>
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31"/>
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31"/>
    <!-- <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" tools:targetApi="31"/> -->

    <!-- Location only for BLE scan on API ≤ 30 -->
    <uses-permission
        android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30"/>

    <!-- Scoped media (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" tools:targetApi="33"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO"  tools:targetApi="33"/>

    <!-- Legacy external storage only for API ≤ 32 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"  android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32"/>

    <!-- Notifications (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" tools:targetApi="33"/>

    <!-- Foreground service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA"           tools:targetApi="34"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"        tools:targetApi="34"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" tools:targetApi="34"/>
    <!-- If your FGS records audio, also add:
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" tools:targetApi="34"/> -->

    <!-- Hardware features -->
    <uses-feature android:name="android.hardware.camera.any" android:required="true"/>
    <uses-feature android:name="android.hardware.microphone" android:required="true"/>
    <uses-feature android:name="android.hardware.bluetooth" android:required="true"/>
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true"/>
    <uses-feature android:name="android.hardware.usb.host" android:required="true"/>

    <application
        android:name="mpdc4gsr.core.App"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="${app_name}"
        android:theme="@style/AppTheme"
        tools:replace="android:label">
        <!-- Optional backups hardening (uncomment after adding @xml/backup_rules files)
        android:dataExtractionRules="@xml/backup_rules"
        android:fullBackupContent="@xml/backup_rules_legacy"
        -->

        <!-- Jetpack Compose Activities -->
        <activity android:name="mpdc4gsr.feature.settings.ui.PolicyComposeActivity"/>
        <activity android:name="mpdc4gsr.feature.settings.ui.VersionComposeActivity"/>

        <activity
            android:name="mpdc4gsr.feature.settings.ui.SettingsComposeActivity"
            android:exported="false"
            android:label="Settings"
            android:theme="@style/AppTheme"/>

        <!-- USB Receiver -->
        <receiver
            android:name="mpdc4gsr.feature.thermal.ui.ThermalUsbReceiver"
            android:exported="false">
            <intent-filter android:priority="1000">
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"/>
                <action android:name="android.hardware.usb.action.USB_DEVICE_DETACHED"/>
                <action android:name="mpdc4gsr.USB_PERMISSION"/>
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/ir_device_filter"/>
        </receiver>

        <activity
            android:name="mpdc4gsr.feature.network.ui.DevicePairingComposeActivity"
            android:exported="false"
            android:label="Device Pairing"
            android:theme="@style/AppTheme"/>

        <activity
            android:name="mpdc4gsr.feature.network.ui.NetworkClientTestComposeActivity"
            android:exported="false"
            android:label="Network Test"
            android:theme="@style/AppTheme"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.MultiModalRecordingComposeActivity"
            android:exported="false"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRQuickRecordingActivity"
            android:exported="false"
            android:label="@string/gsr_quick_access"/>

        <activity
            android:name="mpdc4gsr.feature.testing.ui.FaultTolerantRecordingComposeActivity"
            android:exported="false"
            android:label="@string/enhanced_recording_label"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.SessionManagerComposeActivity"
            android:exported="false"
            android:label="Session Manager"/>
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.ResearchTemplateComposeActivity"
            android:exported="false"
            android:label="Research Templates"/>
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.SessionDetailComposeActivity"
            android:exported="false"
            android:label="Session Details"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRPlotComposeActivity"
            android:exported="false"
            android:label="GSR Data Analysis"
            android:theme="@style/AppTheme"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRDataViewComposeActivity"
            android:exported="false"
            android:label="GSR Data Viewer"
            android:theme="@style/AppTheme"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRVideoPlayerComposeActivity"
            android:exported="false"
            android:label="GSR Video Player"
            android:theme="@style/AppTheme"/>
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.SessionExportComposeActivity"
            android:exported="false"
            android:label="Export Session"/>

        <activity
            android:name="mpdc4gsr.sensors.HubSpokeIntegrationActivity"
            android:exported="false"
            android:label="Hub-Spoke Recording"/>

        <activity
            android:name="mpdc4gsr.core.ui.PermissionRequestComposeActivity"
            android:exported="false"
            android:label="Enhanced Permission System Test"/>

        <activity
            android:name="mpdc4gsr.camera.integration.DualModeCameraComposeActivity"
            android:exported="false"
            android:label="Dual Mode Camera"
            android:theme="@style/AppTheme"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRDeviceManagementComposeActivity"
            android:exported="false"
            android:label="GSR Device Management"
            android:theme="@style/AppTheme"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRRawImageViewComposeActivity"
            android:exported="false"
            android:label="GSR Raw Image Viewer"/>

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRDeviceConfigComposeActivity"
            android:exported="false"
            android:label="GSR Device Configuration"/>

        <!-- Main Launcher Activity -->
        <activity
            android:name="mpdc4gsr.feature.main.ui.MainComposeActivity"
            android:exported="true"
            android:label="MPDC4GSR"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Navigation Demo Activity -->
        <activity
            android:name="mpdc4gsr.compose.navigation.IRCameraNavHost"
            android:exported="false"
            android:label="IR Camera Navigation Demo"
            android:theme="@style/Theme.AppCompat.NoActionBar"/>

        <!-- Navigation Test Activity -->
        <activity
            android:name="mpdc4gsr.feature.testing.ui.NavigationTestActivity"
            android:exported="false"
            android:label="Navigation Test"
            android:theme="@style/Theme.AppCompat.NoActionBar"/>

        <!-- Comprehensive Integration Test Activity -->
        <activity
            android:name="mpdc4gsr.feature.testing.ui.ComprehensiveIntegrationTestActivity"
            android:exported="false"
            android:label="Integration Test Suite"
            android:theme="@style/Theme.AppCompat.NoActionBar"/>

        <!-- Test Activities - Migrated to Compose -->
        <activity
            android:name="mpdc4gsr.compose.testing.GSRBenchTestComposeActivity"
            android:exported="false"
            android:label="GSR Benchmark Test"/>
        <activity
            android:name="mpdc4gsr.compose.testing.GSRDataIntegrityTestComposeActivity"
            android:exported="false"
            android:label="GSR Data Integrity Test"/>
        <activity
            android:name="mpdc4gsr.compose.testing.GSRReconnectionTestComposeActivity"
            android:exported="false"
            android:label="GSR Reconnection Test"/>
        <activity
            android:name="mpdc4gsr.compose.testing.ParallelRecordingTestComposeActivity"
            android:exported="false"
            android:label="Parallel Recording Test"/>
        <activity
            android:name="mpdc4gsr.compose.testing.SessionLifecycleTestComposeActivity"
            android:exported="false"
            android:label="Session Lifecycle Test"/>

        <!-- Camera Activities -->
        <activity
            android:name="mpdc4gsr.camera.integration.DualModeCameraActivity"
            android:exported="false"
            android:label="Dual Mode Camera"/>

        <activity
            android:name="mpdc4gsr.feature.camera.ui.DualModeCameraComposeActivity2"
            android:exported="false"
            android:label="Dual Mode Camera"/>

        <activity
            android:name="mpdc4gsr.compose.testing.RawCaptureTestComposeActivity"
            android:exported="false"
            android:label="Raw Capture Test"/>
        <activity
            android:name="mpdc4gsr.compose.testing.RgbCameraTestComposeActivity"
            android:exported="false"
            android:label="RGB Camera Test"/>

        <!-- Session and Synchronisation Activities -->
        <activity
            android:name="mpdc4gsr.sensors.gsr.CompleteSessionTrialActivity"
            android:exported="false"
            android:label="Complete Session Trial"/>

        <activity
            android:name="mpdc4gsr.compose.testing.CrossModalSyncTestComposeActivity"
            android:exported="false"
            android:label="Cross Modal Sync Test"/>
        <activity
            android:name="mpdc4gsr.sensors.gsr.SynchronizationTestActivity"
            android:exported="false"
            android:label="Synchronization Test"/>
        <activity
            android:name="mpdc4gsr.compose.testing.TimeSynchronizationTestComposeActivity"
            android:exported="false"
            android:label="Time Synchronization Test"/>

        <!-- BLE and Permission Activities - Migrated to Compose -->
        <activity
            android:name="mpdc4gsr.compose.testing.BLEIntegrationTestComposeActivity"
            android:exported="false"
            android:label="BLE Integration Test"/>

        <!-- Jetpack Compose Activities -->
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.SensorDashboardComposeActivity"
            android:exported="false"
            android:label="Sensor Dashboard"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme"/>

        <activity
            android:name="mpdc4gsr.feature.testing.ui.ComposeMigrationLauncherActivity"
            android:exported="false"
            android:label="Compose Migration Launcher"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme">
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/ir_device_filter"/>
        </activity>

        <!-- Recording Service - PC networking and sensor recording -->
        <service
            android:name="mpdc4gsr.core.RecordingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="camera|connectedDevice|dataSync"/>
        <!-- If the service records audio, use: camera|connectedDevice|dataSync|microphone -->

        <!-- File Provider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true"
            tools:replace="android:authorities">
            <meta-data
                android:name="androidx.core.content.FileProvider.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths"
                tools:replace="android:resource"/>
        </provider>
    </application>

</manifest>
