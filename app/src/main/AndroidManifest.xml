<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Essential permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" tools:targetApi="31" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" tools:targetApi="31" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />

    <!-- Hardware features -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <application
        android:name="mpdc4gsr.core.App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="${app_name}"
        android:theme="@style/AppTheme"
        tools:replace="android:label">

        <!-- USB Device Handler Activity -->
        <activity
            android:name="mpdc4gsr.activities.BlankDevActivity"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:exported="true"
            android:theme="@style/Blank">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/ir_device_filter" />
        </activity>

        <!-- Main Launcher Activity -->
        <activity
            android:name="mpdc4gsr.activities.MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Essential Activities -->
        <activity android:name="mpdc4gsr.activities.PolicyActivity" />
        <activity android:name="mpdc4gsr.activities.VersionActivity" />
        <activity android:name="mpdc4gsr.activities.SettingsComposeActivity" 
                  android:exported="false"
                  android:label="Settings (Compose)"
                  android:theme="@style/AppTheme" />

        <!-- USB Receiver -->
        <receiver
            android:name="mpdc4gsr.sensors.thermal.ThermalUsbReceiver"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
                <action android:name="android.hardware.usb.action.USB_DEVICE_DETACHED" />
                <action android:name="mpdc4gsr.USB_PERMISSION" />

        <activity
            android:name="mpdc4gsr.activities.NetworkConfigActivity"
            android:exported="false"
            android:label="Network Configuration"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.MultiModalRecordingActivity"
            android:exported="false" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRQuickRecordingActivity"
            android:exported="false"
            android:label="@string/gsr_quick_access" />

        <activity
            android:name="mpdc4gsr.activities.FaultTolerantRecordingActivity"
            android:exported="false"
            android:label="@string/enhanced_recording_label" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionManagerActivity"
            android:exported="false"
            android:label="Session Manager" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.ResearchTemplateActivity"
            android:exported="false"
            android:label="Research Templates" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionDetailActivity"
            android:exported="false"
            android:label="Session Details" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionDetailComposeActivity"
            android:exported="false"
            android:label="Session Details (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRPlotComposeActivity"
            android:exported="false"
            android:label="GSR Data Analysis (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRDataViewComposeActivity"
            android:exported="false"
            android:label="GSR Data Viewer (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRVideoPlayerComposeActivity"
            android:exported="false"
            android:label="GSR Video Player (Compose)"
            android:theme="@style/AppTheme" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionExportActivity"
            android:exported="false"
            android:label="Export Session" />

        <activity
            android:name="mpdc4gsr.sensors.HubSpokeIntegrationActivity"
            android:exported="false"
            android:label="Hub-Spoke Recording" />

        <activity
            android:name="mpdc4gsr.network.DevicePairingActivity"
            android:exported="false"
            android:label="Device Pairing" />

        <activity
            android:name="mpdc4gsr.activities.DevicePairingActivityCompose"
            android:exported="false"
            android:label="Device Pairing (Compose)" />

        <activity
            android:name="mpdc4gsr.permissions.PermissionRequestActivity"
            android:exported="false"
            android:label="Enhanced Permission System Test" />

        <!-- Network & Device Management - Compose Activities -->
        <activity
            android:name="mpdc4gsr.network.DevicePairingComposeActivity"
            android:exported="false"
            android:label="Device Pairing (Modern)" />

        <activity
            android:name="mpdc4gsr.permissions.PermissionRequestComposeActivity"
            android:exported="false"
            android:label="Permission Manager (Modern)" />

        <!-- Additional GSR Activities -->
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRVideoPlayerActivity"
            android:exported="false"
            android:label="GSR Video Player" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRPlotActivity"
            android:exported="false"
            android:label="GSR Plot Viewer" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRDataViewActivity"
            android:exported="false"
            android:label="GSR Data Viewer" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRSettingsActivity"
            android:exported="false"
            android:label="GSR Settings" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRSettingsComposeActivity"
            android:exported="false"
            android:label="GSR Settings (Compose)"
            android:theme="@style/AppTheme" />

        <!-- New GSR Sensor Compose Activities -->
        <activity
            android:name="mpdc4gsr.sensors.gsr.SessionManagerComposeActivity"
            android:exported="false"
            android:label="Session Manager (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.MultiModalRecordingComposeActivity"
            android:exported="false"
            android:label="Multi-Modal Recording (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.ShimmerConfigComposeActivity"
            android:exported="false"
            android:label="Shimmer Configuration (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.ResearchTemplateComposeActivity"
            android:exported="false"
            android:label="Research Templates (Compose)"
            android:theme="@style/AppTheme" />

        <!-- Network & Device Management Compose Activities -->
        <activity
            android:name="mpdc4gsr.network.DevicePairingComposeActivity"
            android:exported="false"
            android:label="Device Pairing (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.permissions.PermissionRequestComposeActivity"
            android:exported="false"
            android:label="Permission Manager (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.camera.integration.DualModeCameraComposeActivity"
            android:exported="false"
            android:label="Dual Mode Camera (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.sensors.gsr.GSRDeviceManagementComposeActivity"
            android:exported="false"
            android:label="GSR Device Management (Compose)"
            android:theme="@style/AppTheme" />

        <!-- Thermal Camera Module Compose Activities -->
        <activity
            android:name="com.mpdc4gsr.module.thermalunified.activity.ThermalGalleryComposeActivity"
            android:exported="false"
            android:label="Thermal Gallery (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="com.mpdc4gsr.module.thermalunified.report.activity.ThermalReportCreationComposeActivity"
            android:exported="false"
            android:label="Thermal Report Creation (Compose)"
            android:theme="@style/AppTheme" />

        <!-- Additional Thermal Camera Module Compose Activities -->
        <activity
            android:name="com.mpdc4gsr.module.thermalunified.activity.ThermalVideoComposeActivity"
            android:exported="false"
            android:label="Thermal Video Player (Compose)"
            android:theme="@style/AppTheme" />

        <activity
