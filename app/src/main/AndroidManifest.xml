<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Essential permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        tools:targetApi="31" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Granular media permissions for Android 13+ -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        tools:targetApi="33" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        tools:targetApi="33" />

    <!-- Notification permission for Android 13+ -->
    <uses-permission
        android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />

    <!-- Foreground service permissions for Android 14+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_CAMERA"
        tools:targetApi="34" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:targetApi="34" />

    <!-- Hardware features -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.usb.host"
        android:required="false" />

    <application
        android:name="mpdc4gsr.core.App"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="${app_name}"
        android:theme="@style/AppTheme"
        tools:replace="android:label">

        <!-- Jetpack Compose Activities -->
        <activity android:name="mpdc4gsr.feature.settings.ui.PolicyComposeActivity" />
        <activity android:name="mpdc4gsr.feature.settings.ui.VersionComposeActivity" />

        <activity
            android:name="mpdc4gsr.feature.settings.ui.SettingsComposeActivity"
            android:exported="false"
            android:label="Settings (Compose)"
            android:theme="@style/AppTheme" />

        <!-- USB Receiver -->
        <receiver
            android:name="mpdc4gsr.feature.thermal.ui.ThermalUsbReceiver"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
                <action android:name="android.hardware.usb.action.USB_DEVICE_DETACHED" />
                <action android:name="mpdc4gsr.USB_PERMISSION" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/ir_device_filter" />
        </receiver>

        <activity
            android:name="mpdc4gsr.feature.network.ui.NetworkConfigComposeActivity"
            android:exported="false"
            android:label="Network Configuration"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.MultiModalRecordingComposeActivity"
            android:exported="false" />

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRQuickRecordingActivity"
            android:exported="false"
            android:label="@string/gsr_quick_access" />

        <activity
            android:name="mpdc4gsr.feature.testing.ui.FaultTolerantRecordingComposeActivity"
            android:exported="false"
            android:label="@string/enhanced_recording_label" />

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.SessionManagerComposeActivity"
            android:exported="false"
            android:label="Session Manager" />
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.ResearchTemplateComposeActivity"
            android:exported="false"
            android:label="Research Templates" />
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.SessionDetailComposeActivity"
            android:exported="false"
            android:label="Session Details" />

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRPlotComposeActivity"
            android:exported="false"
            android:label="GSR Data Analysis (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRDataViewComposeActivity"
            android:exported="false"
            android:label="GSR Data Viewer (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRVideoPlayerComposeActivity"
            android:exported="false"
            android:label="GSR Video Player (Compose)"
            android:theme="@style/AppTheme" />
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.SessionExportComposeActivity"
            android:exported="false"
            android:label="Export Session" />

        <activity
            android:name="mpdc4gsr.sensors.HubSpokeIntegrationActivity"
            android:exported="false"
            android:label="Hub-Spoke Recording" />

        <activity
            android:name="mpdc4gsr.feature.network.ui.DevicePairingComposeActivity"
            android:exported="false"
            android:label="Device Pairing" />

        <activity
            android:name="mpdc4gsr.core.ui.PermissionRequestComposeActivity"
            android:exported="false"
            android:label="Enhanced Permission System Test" />

        <!-- Duplicate network & device management activities removed - already declared above -->

        <!-- Duplicate GSR activities section removed - activities already declared above -->

        <!-- Duplicate entries removed - these activities are already declared above -->

        <activity
            android:name="mpdc4gsr.camera.integration.DualModeCameraComposeActivity"
            android:exported="false"
            android:label="Dual Mode Camera (Compose)"
            android:theme="@style/AppTheme" />

        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRDeviceManagementComposeActivity"
            android:exported="false"
            android:label="GSR Device Management (Compose)"
            android:theme="@style/AppTheme" />

        <!-- Note: Thermal Camera Module Compose Activities are declared in component/thermalunified/src/main/AndroidManifest.xml -->
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.GSRRawImageViewComposeActivity"
            android:exported="false"
            android:label="GSR Raw Image Viewer (Compose)" />
        <!-- Note: GSRGalleryComposeActivity not implemented yet -->
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.ShimmerConfigComposeActivity"
            android:exported="false"
            android:label="Shimmer Configuration (Compose)" />

        <!-- Main Launcher Activity -->
        <activity
            android:name="mpdc4gsr.feature.main.ui.MainComposeActivity"
            android:exported="true"
            android:label="IR Camera - Compose UI"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Navigation Demo Activity -->
        <activity
            android:name="mpdc4gsr.compose.navigation.IRCameraNavHost"
            android:exported="false"
            android:label="IR Camera Navigation Demo"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Navigation Test Activity -->
        <activity
            android:name="mpdc4gsr.feature.testing.ui.NavigationTestActivity"
            android:exported="true"
            android:label="Navigation Test"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Comprehensive Integration Test Activity -->
        <activity
            android:name="mpdc4gsr.feature.testing.ui.ComprehensiveIntegrationTestActivity"
            android:exported="true"
            android:label="Integration Test Suite"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Test Activities - Migrated to Compose -->
        <activity
            android:name="mpdc4gsr.compose.testing.GSRBenchTestComposeActivity"
            android:exported="false"
            android:label="GSR Benchmark Test (Compose)" />
        <activity
            android:name="mpdc4gsr.compose.testing.GSRDataIntegrityTestComposeActivity"
            android:exported="false"
            android:label="GSR Data Integrity Test (Compose)" />
        <activity
            android:name="mpdc4gsr.compose.testing.GSRReconnectionTestComposeActivity"
            android:exported="false"
            android:label="GSR Reconnection Test (Compose)" />
        <activity
            android:name="mpdc4gsr.compose.testing.ParallelRecordingTestComposeActivity"
            android:exported="false"
            android:label="Parallel Recording Test (Compose)" />
        <activity
            android:name="mpdc4gsr.compose.testing.SessionLifecycleTestComposeActivity"
            android:exported="false"
            android:label="Session Lifecycle Test (Compose)" />

        <!-- Camera Activities -->
        <activity
            android:name="mpdc4gsr.camera.integration.DualModeCameraActivity"
            android:exported="false"
            android:label="Dual Mode Camera" />

        <activity
            android:name="mpdc4gsr.feature.camera.ui.DualModeCameraActivityCompose"
            android:exported="false"
            android:label="Dual Mode Camera (Compose)" />

        <activity
            android:name="mpdc4gsr.compose.testing.RawCaptureTestComposeActivity"
            android:exported="false"
            android:label="Raw Capture Test (Compose)" />
        <activity
            android:name="mpdc4gsr.compose.testing.RgbCameraTestComposeActivity"
            android:exported="false"
            android:label="RGB Camera Test (Compose)" />

        <!-- Session and Synchronization Activities -->
        <activity
            android:name="mpdc4gsr.sensors.gsr.CompleteSessionTrialActivity"
            android:exported="false"
            android:label="Complete Session Trial" />

        <activity
            android:name="mpdc4gsr.compose.testing.CrossModalSyncTestComposeActivity"
            android:exported="false"
            android:label="Cross Modal Sync Test (Compose)" />
        <activity
            android:name="mpdc4gsr.sensors.gsr.SynchronizationTestActivity"
            android:exported="false"
            android:label="Synchronization Test" />
        <activity
            android:name="mpdc4gsr.compose.testing.TimeSynchronizationTestComposeActivity"
            android:exported="false"
            android:label="Time Synchronization Test (Compose)" />

        <!-- BLE and Permission Activities - Migrated to Compose -->
        <activity
            android:name="mpdc4gsr.compose.testing.BLEIntegrationTestComposeActivity"
            android:exported="false"
            android:label="BLE Integration Test (Compose)" />

        <!-- Jetpack Compose Activities -->
        <activity
            android:name="mpdc4gsr.feature.gsr.ui.SensorDashboardComposeActivity"
            android:exported="false"
            android:label="Sensor Dashboard (Compose)"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme" />

        <!-- Duplicate entry removed - SettingsComposeActivity already declared above -->

        <activity
            android:name="mpdc4gsr.feature.testing.ui.ComposeMigrationLauncherActivity"
            android:exported="false"
            android:label="Compose Migration Launcher"
            android:screenOrientation="userPortrait"
            android:theme="@style/AppTheme">
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/ir_device_filter" />
        </activity>

        <!-- Recording Service - Handles PC networking and sensor recording -->
        <service
            android:name="mpdc4gsr.core.RecordingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync|camera" />

        <!-- File Provider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true"
            tools:replace="android:authorities">
            <meta-data
                android:name="androidx.core.content.FileProvider.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths"
                tools:replace="android:resource" />
        </provider>
    </application>

</manifest>
