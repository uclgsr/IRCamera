<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:clipChildren="false"
        android:background="#16131e"
        tools:context="com.topdon.tc001.MainActivity">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_page"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/network_status_bar"
            app:layout_constraintBottom_toTopOf="@+id/cl_bottom" />

        <!-- Network Status Indicator -->
        <LinearLayout
            android:id="@+id/network_status_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#AA000000"
            android:gravity="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <ImageView
                android:id="@+id/network_status_indicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="4dp"
                android:src="@android:drawable/presence_invisible"
                android:contentDescription="Network status" />
                
            <TextView
                android:id="@+id/network_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PC: Disconnected"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
                
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_bottom"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="375:56"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_bottom_main_bg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_main_bg_not_select"
                android:contentDescription="@null"
                app:layout_constraintDimensionRatio="1125:255"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <View
                android:id="@+id/view_main"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintWidth_percent="0.28"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- 图Library -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_icon_gallery"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintWidth_percent="0.28"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/view_main">
                <ImageView
                    android:id="@+id/iv_icon_gallery"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/selector_gallery"
                    android:contentDescription="@null"
                    app:layout_constraintWidth_percent="0.17"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/tv_icon_gallery" />
                <TextView
                    android:id="@+id/tv_icon_gallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/tc_local_album"
                    android:textSize="@dimen/app_font_11"
                    android:textColor="@color/tab_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_icon_gallery"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 我的 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_icon_mine"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintWidth_percent="0.28"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/view_main">
                <ImageView
                    android:id="@+id/iv_icon_mine"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/selector_mine"
                    android:contentDescription="@null"
                    app:layout_constraintWidth_percent="0.17"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/tv_icon_mine" />
                <View
                    android:id="@+id/view_mine_point"
                    android:layout_width="8sp"
                    android:layout_height="8sp"
                    android:layout_marginTop="-2dp"
                    android:background="@drawable/shape_oval_ff0000"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:ignore="SmallSp"
                    app:layout_constraintTop_toTopOf="@id/iv_icon_mine"
                    app:layout_constraintStart_toEndOf="@id/iv_icon_mine" />
                <TextView
                    android:id="@+id/tv_icon_mine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/main_mine"
                    android:textSize="@dimen/app_font_11"
                    android:textColor="@color/tab_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_icon_mine"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    
</layout>