<?xml version="1.0" encoding="utf-8"?><!--
    Scrollable Sensor Dashboard Fragment Layout
    
    This layout implements a fully scrollable multi-modal sensor dashboard that can be 
    dropped into any Activity or Fragment container. All content is contained within 
    a ScrollView to ensure proper scrolling behavior on all device sizes.
    
    Key Features:
    - Root ScrollView with fillViewport for full height utilization
    - Visible scroll indicators with overScrollMode for user feedback
    - Minimum height constraints to ensure content is always scrollable
    - Extra padding for better touch interaction
    - Dividers between sensor items for visual separation
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent"
    android:layout_height="match_parent" android:fillViewport="true" android:overScrollMode="always"
    android:scrollbarStyle="outsideOverlay" android:scrollbars="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="300dp"
        android:orientation="vertical" android:padding="16dp">

        <!-- Title Section -->
        <TextView android:id="@+id/titleText" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:padding="8dp" android:text="Multi-Modal Sensor Dashboard"
            android:textColor="@android:color/primary_text_dark" android:textSize="18sp" android:textStyle="bold" />

        <!-- Overall Status Section -->
        <TextView android:id="@+id/overallStatusText" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:gravity="center" android:padding="8dp"
            android:text="System Status: Initializing..." android:textColor="@android:color/secondary_text_dark"
            android:textSize="14sp" />

        <!-- Recording Status Section with interactive background -->
        <LinearLayout android:id="@+id/recordingSection" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginVertical="4dp"
            android:background="?android:attr/selectableItemBackground" android:gravity="center"
            android:orientation="horizontal" android:padding="8dp">

            <ImageView android:id="@+id/recordingIndicator" android:layout_width="24dp" android:layout_height="24dp"
                android:layout_marginEnd="8dp" android:background="@android:color/darker_gray"
                android:contentDescription="Recording status indicator" />

            <TextView android:id="@+id/recordingTimer" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Ready to Record"
                android:textColor="@android:color/primary_text_dark" android:textSize="14sp" />

        </LinearLayout>

        <!-- Sensors Title with Collapse/Expand Toggle -->
        <LinearLayout android:id="@+id/sensorsTitleContainer" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:background="?android:attr/selectableItemBackground"
            android:clickable="true" android:focusable="true" android:orientation="horizontal" android:padding="8dp">

            <TextView android:id="@+id/sensorsTitle" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Sensor Connections"
                android:textColor="@android:color/primary_text_dark" android:textSize="16sp" android:textStyle="bold" />

            <ImageView android:id="@+id/collapseExpandIcon" android:layout_width="24dp" android:layout_height="24dp"
                android:layout_gravity="center_vertical" android:contentDescription="Expand/Collapse sensors"
                android:src="@android:drawable/arrow_down_float" />

        </LinearLayout>

        <!-- 
            Sensors Container - All sensor status views are added here programmatically
            The parent ScrollView handles all scrolling - no nested scrolling issues
            Dividers provide visual separation between sensor items
        -->
        <LinearLayout android:id="@+id/sensorsContainer" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:divider="@android:drawable/divider_horizontal_bright"
            android:minHeight="200dp" android:orientation="vertical" android:padding="8dp"
            android:showDividers="middle">

            <!-- Individual sensor status views will be added programmatically -->

        </LinearLayout>

        <!-- Extra spacing to ensure proper scrolling and touch area at bottom -->
        <Space android:layout_width="match_parent" android:layout_height="100dp" />

    </LinearLayout>

</ScrollView>