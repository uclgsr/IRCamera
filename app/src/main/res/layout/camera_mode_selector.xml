<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@drawable/rounded_background">

    <!-- Camera Mode Title -->
    <TextView
        android:id="@+id/mode_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Camera Mode"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mode Selection RadioGroup -->
    <RadioGroup
        android:id="@+id/mode_segmented_control"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/mode_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioButton
            android:id="@+id/raw_mode_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="RAW 50MP"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/segmented_button_left"
            android:button="@null"
            android:textColor="@color/segmented_button_text"
            android:drawablePadding="4dp"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/video_mode_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="4K Video"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/segmented_button_middle"
            android:button="@null"
            android:textColor="@color/segmented_button_text"
            android:drawablePadding="4dp"
            android:padding="8dp" />

        <RadioButton
            android:id="@+id/preview_mode_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Preview"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/segmented_button_right"
            android:button="@null"
            android:textColor="@color/segmented_button_text"
            android:drawablePadding="4dp"
            android:padding="8dp" />

    </RadioGroup>

    <!-- Switching Progress Bar -->
    <ProgressBar
        android:id="@+id/switching_progress_bar"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:visibility="gone"
        android:indeterminate="true"
        app:layout_constraintTop_toTopOf="@id/mode_segmented_control"
        app:layout_constraintBottom_toBottomOf="@id/mode_segmented_control"
        app:layout_constraintStart_toStartOf="@id/mode_segmented_control"
        app:layout_constraintEnd_toEndOf="@id/mode_segmented_control" />

    <!-- Mode Information Text -->
    <TextView
        android:id="@+id/mode_info_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingExtra="2dp"
        app:layout_constraintTop_toBottomOf="@id/mode_segmented_control"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Preview mode only\nLow power consumption" />

    <!-- Performance Warning -->
    <TextView
        android:id="@+id/performance_warning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="12sp"
        android:textColor="@android:color/holo_orange_dark"
        android:textStyle="italic"
        android:visibility="gone"
        android:drawableStart="@drawable/ic_warning"
        android:drawablePadding="4dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/mode_info_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="RAW mode uses significant memory and storage"
        tools:visibility="visible" />

    <!-- Device Compatibility Info -->
    <TextView
        android:id="@+id/device_compatibility_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="11sp"
        android:textColor="@color/text_tertiary"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/performance_warning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>