<?xml version="1.0" encoding="utf-8"?><!-- Consolidated Main Activity Layout - Base layout that supports multi-modal recording -->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <!-- Data binding placeholder for sensor state -->
        <variable
            name="sensorMode"
            type="String" />

        <variable
            name="recordingEnabled"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#16131e"
        android:clipChildren="false"
        android:fitsSystemWindows="true"
        tools:context="com.mpdc4gsr.tc001.MainActivity">

        <!-- Network Status Bar (Minimal) -->
        <LinearLayout
            android:id="@+id/network_status_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#AA000000"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp"
            android:visibility="@{recordingEnabled ? View.VISIBLE : View.GONE}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/thermal_quick_access"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="Thermal Camera"
                android:src="@android:drawable/ic_search_category_default"
                android:tint="#FF6B35" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/network_status_indicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="Network status"
                android:src="@android:drawable/presence_invisible" />

            <TextView
                android:id="@+id/network_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PC: Disconnected"
                android:textColor="#FFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Sensor Controls Container (Collapsible) -->
        <FrameLayout
            android:id="@+id/sensor_controls_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF1A1A1A"
            android:visibility="@{sensorMode != null ? View.VISIBLE : View.GONE}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/network_status_bar" />

        <!-- Main Content ViewPager -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_page"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@+id/cl_bottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/sensor_controls_container" />

        <!-- Bottom Navigation (Reused from Original) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_bottom"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="375:56"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_bottom_main_bg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/ic_main_bg_not_select"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1125:255"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Gallery Tab -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_icon_gallery"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/view_main"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_icon_gallery"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@null"
                    android:src="@drawable/selector_gallery"
                    app:layout_constraintBottom_toTopOf="@+id/tv_icon_gallery"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.17" />

                <TextView
                    android:id="@+id/tv_icon_gallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="@string/tc_local_album"
                    android:textColor="@color/tab_text"
                    android:textSize="@dimen/app_font_11"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_icon_gallery" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Center Space -->
            <View
                android:id="@+id/view_main"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cl_icon_settings"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/cl_icon_gallery"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Settings Tab -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_icon_settings"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cl_icon_mine"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/view_main"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_icon_settings"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@string/main_settings"
                    android:src="@drawable/selector_settings"
                    app:layout_constraintBottom_toTopOf="@+id/tv_icon_settings"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.17" />

                <TextView
                    android:id="@+id/tv_icon_settings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="@string/main_settings"
                    android:textColor="@color/tab_text"
                    android:textSize="@dimen/app_font_11"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_icon_settings" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Mine Tab -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_icon_mine"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@id/cl_icon_settings"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_icon_mine"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@null"
                    android:src="@drawable/selector_mine"
                    app:layout_constraintBottom_toTopOf="@+id/tv_icon_mine"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.17" />

                <TextView
                    android:id="@+id/tv_icon_mine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="@string/main_mine"
                    android:textColor="@color/tab_text"
                    android:textSize="@dimen/app_font_11"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_icon_mine" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>