<?xml version="1.0" encoding="utf-8"?>
<!-- Consolidated Device Item - Replaces item_gsr_device.xml, item_shimmer_device_detailed.xml, and others -->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="deviceName"
            type="String" />
        <variable
            name="deviceType"
            type="String" />
        <variable
            name="deviceId"
            type="String" />
        <variable
            name="isConnected"
            type="Boolean" />
        <variable
            name="signalStrength"
            type="Integer" />
        <variable
            name="batteryLevel"
            type="Integer" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="4dp"
        app:cardBackgroundColor="@color/background_card"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Device Icon -->
            <ImageView
                android:id="@+id/device_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="Device icon"
                android:src="@{deviceType.equals(@string/thermal_sensor_type) ? @drawable/ic_thermal : deviceType.equals(@string/gsr_sensor_type) ? @drawable/ic_gsr_pulse : @drawable/ic_sensor_generic}"
                android:tint="@{isConnected ? @color/status_connected : @color/status_disconnected}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:src="@drawable/ic_gsr_pulse" />

            <!-- Connection Status Indicator -->
            <View
                android:id="@+id/connection_indicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="4dp"
                android:background="@drawable/shape_oval_ff0000"
                android:backgroundTint="@{isConnected ? @color/status_connected : @color/status_disconnected}"
                app:layout_constraintEnd_toEndOf="@+id/device_icon"
                app:layout_constraintTop_toTopOf="@+id/device_icon" />

            <!-- Device Name -->
            <TextView
                android:id="@+id/device_name_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@{deviceName ?? @string/unknown_device}"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/signal_strength_icon"
                app:layout_constraintStart_toEndOf="@+id/device_icon"
                app:layout_constraintTop_toTopOf="@+id/device_icon"
                tools:text="Shimmer GSR Sensor" />

            <!-- Device Type -->
            <TextView
                android:id="@+id/device_type_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:text="@{deviceType ?? @string/unknown_type}"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@+id/signal_strength_icon"
                app:layout_constraintStart_toEndOf="@+id/device_icon"
                app:layout_constraintTop_toBottomOf="@+id/device_name_text"
                tools:text="GSR Sensor" />

            <!-- Device ID -->
            <TextView
                android:id="@+id/device_id_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="monospace"
                android:text="@{deviceId ?? @string/no_id}"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                app:layout_constraintEnd_toStartOf="@+id/signal_strength_icon"
                app:layout_constraintStart_toEndOf="@+id/device_icon"
                app:layout_constraintTop_toBottomOf="@+id/device_type_text"
                tools:text="00:11:22:33:44:55" />

            <!-- Signal Strength Icon -->
            <ImageView
                android:id="@+id/signal_strength_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="Signal strength"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="@color/signal_strength_color"
                android:visibility="@{isConnected ? View.VISIBLE : View.GONE}"
                app:layout_constraintEnd_toStartOf="@+id/battery_level_text"
                app:layout_constraintTop_toTopOf="parent"
                tools:visibility="visible" />

            <!-- Battery Level -->
            <TextView
                android:id="@+id/battery_level_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@{isConnected ? batteryLevel + @string/percent_symbol : @string/empty}"
                android:textColor="@color/battery_level_color"
                android:textSize="12sp"
                android:visibility="@{isConnected ? View.VISIBLE : View.GONE}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="85%"
                tools:visibility="visible" />

            <!-- Connection Status Text -->
            <TextView
                android:id="@+id/connection_status_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="8dp"
                android:text="@{isConnected ? @string/status_connected : @string/status_disconnected}"
                android:textColor="@{isConnected ? @color/status_connected : @color/status_disconnected}"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/device_icon"
                app:layout_constraintTop_toBottomOf="@+id/device_id_text"
                tools:text="Connected" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/device_icon"
                app:layout_constraintTop_toBottomOf="@+id/connection_status_text">

                <Button
                    android:id="@+id/connect_disconnect_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="@{isConnected ? @string/disconnect : @string/connect}"
                    android:textColor="@color/primary_color"
                    android:textSize="12sp"
                    tools:text="Disconnect" />

                <Button
                    android:id="@+id/settings_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</layout>