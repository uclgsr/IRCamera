<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enhanced_fault_tolerant_recording_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:textColor="@color/text_primary" />

    <!-- Status text -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/initializing_enhanced_recording_system"
        android:layout_marginBottom="16dp"
        android:textColor="@color/text_primary" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="?android:attr/progressBarStyleHorizontal"
        android:visibility="gone" />

    <!-- Sensor status -->
    <TextView
        android:id="@+id/sensor_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sensor_status_initializing"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:textColor="@color/text_secondary" />

    <!-- Start button -->
    <Button
        android:id="@+id/start_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/start_enhanced_recording"
        android:enabled="false"
        android:layout_marginBottom="8dp" />

    <!-- Stop button -->
    <Button
        android:id="@+id/stop_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/stop_recording"
        android:enabled="false"
        android:layout_marginBottom="8dp" />

    <!-- Back button -->
    <Button
        android:id="@+id/back_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/back" />

</LinearLayout>