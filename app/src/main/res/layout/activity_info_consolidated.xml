<?xml version="1.0" encoding="utf-8"?><!-- Consolidated Info Activity - Replaces version, policy, clause, and help activities -->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="infoType"
            type="String" />

        <variable
            name="title"
            type="String" />

        <variable
            name="content"
            type="String" />

        <variable
            name="hasWebView"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/c_bg_white">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_color"
            android:theme="@style/ThemeOverlay.AppCompat.ActionBar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:title="@{title ?? @string/app_info}"
            app:titleTextColor="@color/white"
            tools:title="App Information" />

        <!-- Content Container -->
        <FrameLayout
            android:id="@+id/content_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@+id/cl_bottom_navigation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbar">

            <!-- ScrollView for text content -->
            <ScrollView
                android:id="@+id/text_content_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="@{!hasWebView ? View.VISIBLE : View.GONE}">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Dynamic content based on info type -->
                    <TextView
                        android:id="@+id/content_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:text="@{content ?? @string/loading_content}"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        tools:text="App Version: 1.0.0\nBuild: Debug\nDevice: Samsung Galaxy S22\n\nThis application provides multi-modal recording capabilities..." />

                    <!-- Version info section (conditional) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="@{infoType.equals(@string/version_info) ? View.VISIBLE : View.GONE}"
                        app:cardBackgroundColor="#FF2A2A2A"
                        app:cardCornerRadius="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:text="System Information"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/system_info_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:text="Loading system information..."
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Action buttons section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal"
                        android:visibility="@{infoType.equals(@string/version_info) ? View.VISIBLE : View.GONE}">

                        <Button
                            android:id="@+id/check_updates_button"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="Check Updates"
                            android:textColor="@color/primary_color" />

                        <Button
                            android:id="@+id/send_feedback_button"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="Send Feedback"
                            android:textColor="@color/primary_color" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <!-- WebView for web content -->
            <WebView
                android:id="@+id/web_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="@{hasWebView ? View.VISIBLE : View.GONE}" />

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/loading_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Bottom Navigation following original IRCamera architecture -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_bottom_navigation"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#16131e"
            app:layout_constraintDimensionRatio="375:56"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/iv_bottom_main_bg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_main_bg_not_select"
                android:contentDescription="@null"
                app:layout_constraintDimensionRatio="1125:255"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <View
                android:id="@+id/view_main_center"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintWidth_percent="0.28"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Gallery Tab -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_nav_gallery"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintWidth_percent="0.28"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/view_main_center">
                
                <ImageView
                    android:id="@+id/iv_nav_gallery"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/selector_gallery"
                    android:contentDescription="@string/tc_local_album"
                    app:layout_constraintWidth_percent="0.17"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/tv_nav_gallery" />
                
                <TextView
                    android:id="@+id/tv_nav_gallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/tc_local_album"
                    android:textSize="@dimen/app_font_11"
                    android:textColor="@color/tab_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_nav_gallery"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Mine Tab -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_nav_mine"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintWidth_percent="0.28"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/view_main_center">
                
                <ImageView
                    android:id="@+id/iv_nav_mine"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:src="@drawable/selector_mine"
                    android:contentDescription="@string/main_mine"
                    app:layout_constraintWidth_percent="0.17"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/tv_nav_mine" />
                
                <TextView
                    android:id="@+id/tv_nav_mine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/main_mine"
                    android:textSize="@dimen/app_font_11"
                    android:textColor="@color/tab_text"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_nav_mine"
                    app:layout_constraintBottom_toBottomOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>