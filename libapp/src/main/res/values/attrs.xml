<?xml version="1.0" encoding="utf-8"?>
<resources>

    
    <declare-styleable name="MenuSecondView">
        <attr name="deviceType" format="enum">
            <enum name="single_light" value="0" /> 
            <enum name="double_light" value="1" /> 
            <enum name="lite" value="2" />         
            <enum name="tc007" value="3" />        
            <enum name="gallery_edit" value="4" /> 
        </attr>
    </declare-styleable>

    <declare-styleable name="LoadingDots">
        <attr name="lms_dot_spacing" format="dimension" />
        <attr name="lms_dot_radius" format="dimension" />
        <attr name="lms_dot_move_rate" format="float" />
    </declare-styleable>

    <!-- Custom attributes for UI components -->
    <attr name="titleText" format="string" />
    <attr name="start_height" format="dimension" />

    <!-- MyTextView custom attributes -->
    <declare-styleable name="MyTextView">
        <attr name="MyTextView_drawable_height" format="dimension" />
        <attr name="MyTextView_top_height" format="dimension" />
        <attr name="MyTextView_bottom_height" format="dimension" />
        <attr name="MyTextView_start_height" format="dimension" />
        <attr name="MyTextView_end_height" format="dimension" />
        <attr name="MyTextView_left_height" format="dimension" />
        <attr name="MyTextView_right_height" format="dimension" />
    </declare-styleable>

    <!-- TitleView custom attributes -->
    <declare-styleable name="TitleView">
        <attr name="TitleView_leftText" format="string" />
        <attr name="TitleView_leftDrawable" format="reference" />
        <attr name="TitleView_leftTextColor" format="color" />
        <attr name="TitleView_isInitLeft" format="boolean" />
        <attr name="TitleView_rightText" format="string" />
        <attr name="TitleView_rightDrawable" format="reference" />
        <attr name="TitleView_rightTextColor" format="color" />
        <attr name="TitleView_right2Drawable" format="reference" />
        <attr name="TitleView_right3Drawable" format="reference" />
        <attr name="TitleView_isTitleCenter" format="boolean" />
        <attr name="TitleView_titleText" format="string" />
    </declare-styleable>

</resources>
