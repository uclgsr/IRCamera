[flake8]
max-line-length = 88
extend-ignore =
    E203,  # Whitespace before ':', conflicts with black
    W503,  # Line break before binary operator, conflicts with black

exclude =
    .git,
    __pycache__,
    .eggs,
    build,
    dist,
    venv,
    .venv,
    docs,
    migrations, # Often useful to exclude auto-generated migration files
    migration_backup_*

per-file-ignores =
    __init__.py: F401
    tests/*.py: S101

# Verbosity and Reporting
count = True
statistics = True
show-source = True

# Plugin Settings
max-complexity = 15