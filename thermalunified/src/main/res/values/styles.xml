<resources>

    <style name="SeekBarAnimation">
        <item name="android:windowEnterAnimation">@anim/default_dialog_in</item>
        <item name="android:windowExitAnimation">@anim/default_dialog_out</item>
    </style>

    <style name="TextInputDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <style name="TransparentDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="TempTitleStyle">
        <item name="android:textColor">@color/temp_font_color</item>
        <item name="android:textSize">@dimen/app_font_15</item>
    </style>

    <style name="TempNormalStyle">
        <item name="android:textColor">@color/temp_font_second_color</item>
        <item name="android:textSize">@dimen/app_font_13</item>
    </style>

    <!-- Add the missing Theme.IRCamera style for Compose activities -->
    <style name="Theme.IRCamera" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/color_16131E</item>
        <item name="android:windowBackground">@color/color_16131E</item>
    </style>

    <declare-styleable name="MessageSettingItem">
        <attr name="iconImg" format="reference|integer" />
        <attr name="textTitle" format="reference|integer" />
        <attr name="iconSwitch" format="reference|integer" />
        <attr name="lineShow" format="boolean" />
    </declare-styleable>
    <declare-styleable name="ListItemView">
        <attr name="list_item_left_icon" format="string" />
        <attr name="list_item_left_text" format="string" />
        <attr name="list_item_right_text" format="string" />
        <attr name="list_item_line" format="boolean" />
    </declare-styleable>

</resources>
