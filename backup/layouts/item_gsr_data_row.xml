<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground" android:orientation="horizontal"
    android:padding="8dp">

    <TextView android:id="@+id/row_number" android:layout_width="50dp"
        android:layout_height="wrap_content" android:fontFamily="monospace" android:gravity="center"
        android:text="1" android:textColor="#888888" android:textSize="12sp" />

    <TextView android:id="@+id/timestamp" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="2"
        android:fontFamily="monospace" android:paddingHorizontal="8dp"
        android:text="2024-01-15 14:30:25.123" android:textColor="#ffffff"
        android:textSize="12sp" />

    <TextView android:id="@+id/gsr_value" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:fontFamily="monospace" android:gravity="center" android:text="15.456 μS"
        android:textColor="@color/colorAccent" android:textSize="12sp" android:textStyle="bold" />

    <TextView android:id="@+id/resistance" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:fontFamily="monospace" android:gravity="center" android:text="64.8 kΩ"
        android:textColor="#ccffffff" android:textSize="12sp" />

    <TextView android:id="@+id/conductance" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_weight="1"
        android:fontFamily="monospace" android:gravity="center" android:text="0.000015 S"
        android:textColor="#ccffffff" android:textSize="12sp" />

</LinearLayout>
