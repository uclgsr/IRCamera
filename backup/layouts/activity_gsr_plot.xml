<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <!-- Data binding placeholder -->
    </data>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@color/white">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">


            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="300dp"
                android:layout_marginBottom="16dp" app:cardCornerRadius="8dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:padding="8dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp" android:gravity="center"
                        android:text="GSR (Galvanic Skin Response)" android:textColor="@color/black"
                        android:textSize="16sp" android:textStyle="bold" />

                    <com.mpdc4gsr.libunified.ui.charts.LineChart android:id="@+id/gsr_chart"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="300dp"
                android:layout_marginBottom="16dp" app:cardCornerRadius="8dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="vertical" android:padding="8dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp" android:gravity="center"
                        android:text="PPG (Photoplethysmography)" android:textColor="@color/black"
                        android:textSize="16sp" android:textStyle="bold" />

                    <com.mpdc4gsr.libunified.ui.charts.LineChart android:id="@+id/ppg_chart"
                        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="8dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp" android:gravity="center" android:text=" Data Analysis"
                        android:textColor="@color/black" android:textSize="18sp" android:textStyle="bold" />

                    <TextView android:id="@+id/stats_text_view" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.2" android:text="Loading statistics..."
                        android:textColor="@color/black" android:textSize="12sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="#E3F2FD" app:cardCornerRadius="8dp" app:cardElevation="4dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp" android:text="💡 Chart Interaction"
                        android:textColor="@color/black" android:textSize="16sp" android:textStyle="bold" />

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.3"
                        android:text="• Pinch to zoom in/out\n• Drag to pan across timeline\n• Raw data shows actual readings\n• Moving average smooths out noise\n• Events indicate significant changes"
                        android:textColor="@color/black" android:textSize="14sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>
</layout>
