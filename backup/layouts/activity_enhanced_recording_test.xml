<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent"
    android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp">


    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" android:gravity="center"
        android:text="Enhanced Recording Session Controller Test" android:textSize="18sp" android:textStyle="bold" />


    <TextView android:id="@+id/statusDisplay" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" android:background="#E3F2FD" android:gravity="center" android:padding="12dp"
        android:text="Idle - Ready to start recording" android:textSize="16sp" android:textStyle="bold" />


    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"
        android:text="Select Sensors:" android:textSize="14sp" android:textStyle="bold" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" android:orientation="horizontal">

        <CheckBox android:id="@+id/checkboxRgb" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:checked="true" android:text="RGB Camera" />

        <CheckBox android:id="@+id/checkboxThermal" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:checked="true" android:text="Thermal Camera" />

        <CheckBox android:id="@+id/checkboxGsr" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:checked="true" android:text="GSR Sensor" />

    </LinearLayout>


    <CheckBox android:id="@+id/checkboxAllowPartial" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:checked="true"
        android:text="Allow Partial Start (continue even if some sensors fail)" />


    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" android:orientation="horizontal">

        <Button android:id="@+id/buttonStartSession" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_marginEnd="8dp" android:layout_weight="1" android:backgroundTint="#4CAF50"
            android:text="Start Session" />

        <Button android:id="@+id/buttonStopSession" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:backgroundTint="#F44336" android:enabled="false"
            android:text="Stop Session" />

    </LinearLayout>


    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" android:orientation="horizontal">

        <Button android:id="@+id/buttonAddSyncMarker" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_marginEnd="4dp" android:layout_weight="1" android:backgroundTint="#FF9800"
            android:enabled="false" android:text="Add Sync Marker" />

        <Button android:id="@+id/buttonSessionStatus" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_marginStart="4dp" android:layout_weight="1" android:backgroundTint="#2196F3"
            android:text="Session Status" />

    </LinearLayout>


    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" android:orientation="horizontal">

        <Button android:id="@+id/buttonCheckCrashRecovery" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:layout_weight="1"
            android:backgroundTint="#9C27B0" android:text="Check Crash Recovery" />

        <Button android:id="@+id/buttonClearLogs" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_marginStart="4dp" android:layout_weight="1" android:backgroundTint="#607D8B"
            android:text="Clear Logs" />

    </LinearLayout>


    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"
        android:text="Activity Log:" android:textSize="14sp" android:textStyle="bold" />

    <ScrollView android:id="@+id/scrollView" android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:background="#F5F5F5" android:padding="8dp">

        <TextView android:id="@+id/logOutput" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:fontFamily="monospace" android:textColor="#333333" android:textSize="12sp" />

    </ScrollView>

</LinearLayout>