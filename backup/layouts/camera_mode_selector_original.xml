<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent"
    android:layout_height="wrap_content" android:background="@drawable/rounded_background"
    android:padding="16dp">


    <TextView android:id="@+id/mode_title" android:layout_width="0dp"
        android:layout_height="wrap_content" android:text="Camera Mode"
        android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <RadioGroup android:id="@+id/mode_segmented_control" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginTop="12dp"
        android:orientation="horizontal" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mode_title">

        <RadioButton android:id="@+id/raw_mode_button" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:background="@drawable/segmented_button_left" android:button="@null"
            android:drawablePadding="4dp" android:gravity="center" android:padding="8dp"
            android:text="RAW 50MP" android:textColor="@color/segmented_button_text"
            android:textSize="12sp" />

        <RadioButton android:id="@+id/video_mode_button" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:background="@drawable/segmented_button_middle" android:button="@null"
            android:drawablePadding="4dp" android:gravity="center" android:padding="8dp"
            android:text="4K Video" android:textColor="@color/segmented_button_text"
            android:textSize="12sp" />

        <RadioButton android:id="@+id/preview_mode_button" android:layout_width="0dp"
            android:layout_height="48dp" android:layout_weight="1"
            android:background="@drawable/segmented_button_right" android:button="@null"
            android:drawablePadding="4dp" android:gravity="center" android:padding="8dp"
            android:text="Preview" android:textColor="@color/segmented_button_text"
            android:textSize="12sp" />

    </RadioGroup>


    <ProgressBar android:id="@+id/switching_progress_bar" android:layout_width="24dp"
        android:layout_height="24dp" android:indeterminate="true" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/mode_segmented_control"
        app:layout_constraintEnd_toEndOf="@id/mode_segmented_control"
        app:layout_constraintStart_toStartOf="@id/mode_segmented_control"
        app:layout_constraintTop_toTopOf="@id/mode_segmented_control" />


    <TextView android:id="@+id/mode_info_text" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginTop="12dp"
        android:lineSpacingExtra="2dp" android:textColor="@color/text_secondary"
        android:textSize="14sp" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mode_segmented_control"
        tools:text="Preview mode only\nLow power consumption" />


    <TextView android:id="@+id/performance_warning" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginTop="8dp"
        android:drawableStart="@drawable/ic_warning" android:drawablePadding="4dp"
        android:gravity="center_vertical" android:textColor="@android:color/holo_orange_dark"
        android:textSize="12sp" android:textStyle="italic" android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mode_info_text"
        tools:text="RAW mode uses significant memory and storage" tools:visibility="visible" />


    <TextView android:id="@+id/device_compatibility_info" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginTop="8dp"
        android:textColor="@color/text_tertiary" android:textSize="11sp" android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/performance_warning" />

</androidx.constraintlayout.widget.ConstraintLayout>
