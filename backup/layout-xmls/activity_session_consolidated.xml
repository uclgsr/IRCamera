<?xml version="1.0" encoding="utf-8"?><!-- Consolidated Session Management Activity - Replaces session detail, manager, and export activities -->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="sessionMode"
            type="String" />

        <variable
            name="sessionData"
            type="Object" />

        <variable
            name="isExporting"
            type="Boolean" />

        <variable
            name="hasData"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/c_bg_white">

        <ScrollView
            android:id="@+id/main_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toTopOf="@+id/cl_bottom_navigation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header Section -->
                <TextView
                    android:id="@+id/session_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center"
                    android:text="@{sessionMode ?? @string/session_management}"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Session Management" />

                <!-- Session Info Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FF2A2A2A"
                    app:cardCornerRadius="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Session Information"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/session_info_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#FF1A1A1A"
                            android:fontFamily="monospace"
                            android:padding="8dp"
                            android:text="@{sessionData != null ? sessionData.toString() : @string/no_session_data}"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            tools:text="Session ID: session_2024_001\nDuration: 15:32\nSensors: GSR, RGB, Thermal" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Session Actions Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FF2A2A2A"
                    app:cardCornerRadius="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="Session Actions"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/view_data_button"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:enabled="@{hasData}"
                                android:text="View Data"
                                android:textColor="@color/primary_color"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/export_button"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:enabled="@{hasData &amp;&amp; !isExporting}"
                                android:text="@{isExporting ? @string/exporting : @string/export}"
                                android:textColor="@color/primary_color"
                                android:textSize="12sp"
                                tools:text="Export" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/analyze_button"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:enabled="@{hasData}"
                                android:text="Analyze"
                                android:textColor="@color/primary_color"
                                android:textSize="12sp" />

                            <Button
                                android:id="@+id/delete_button"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:text="Delete"
                                android:textColor="@color/red"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Export Progress Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="@{isExporting ? View.VISIBLE : View.GONE}"
                    app:cardBackgroundColor="#FF2A2A2A"
                    app:cardCornerRadius="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Export Progress"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/export_progress"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/export_status_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Exporting session data..."
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Session List/Detail Container -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FF2A2A2A"
                    app:cardCornerRadius="8dp">

                    <FrameLayout
                        android:id="@+id/session_content_container"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <!-- Placeholder for dynamic content (list or detail view) -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="Session content will load here"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </FrameLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <!-- Bottom Navigation following original IRCamera architecture -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_bottom_navigation"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#16131e"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="375:56"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/iv_bottom_main_bg"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/ic_main_bg_not_select"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1125:255"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <View
                android:id="@+id/view_main_center"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.28" />

            <!-- Gallery Tab -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_nav_gallery"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/view_main_center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.28">

                <ImageView
                    android:id="@+id/iv_nav_gallery"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@string/tc_local_album"
                    android:src="@drawable/selector_gallery"
                    app:layout_constraintBottom_toTopOf="@+id/tv_nav_gallery"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.17" />

                <TextView
                    android:id="@+id/tv_nav_gallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="@string/tc_local_album"
                    android:textColor="@color/tab_text"
                    android:textSize="@dimen/app_font_11"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_nav_gallery" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Mine Tab -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_nav_mine"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/view_main_center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.28">

                <ImageView
                    android:id="@+id/iv_nav_mine"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@string/main_mine"
                    android:src="@drawable/selector_mine"
                    app:layout_constraintBottom_toTopOf="@+id/tv_nav_mine"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:layout_constraintWidth_percent="0.17" />

                <TextView
                    android:id="@+id/tv_nav_mine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:text="@string/main_mine"
                    android:textColor="@color/tab_text"
                    android:textSize="@dimen/app_font_11"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iv_nav_mine" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>