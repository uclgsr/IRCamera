<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent"
    android:layout_height="wrap_content" android:layout_margin="8dp" app:cardBackgroundColor="#1a1a1a"
    app:cardCornerRadius="8dp" app:cardElevation="4dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:gravity="center_vertical" android:orientation="horizontal">

            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="12dp"
                android:src="@drawable/ic_device_type_pc" android:tint="@color/colorAccent" />

            <TextView android:id="@+id/controller_name" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="PC Controller" android:textColor="#ffffff"
                android:textSize="16sp" android:textStyle="bold" />

            <Button android:id="@+id/connect_button" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:backgroundTint="@color/colorAccent"
                android:minHeight="32dp" android:paddingStart="16dp" android:paddingEnd="16dp" android:text="Connect"
                android:textColor="#ffffff" android:textSize="12sp" />

        </LinearLayout>

        <TextView android:id="@+id/controller_ip" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginStart="36dp" android:layout_marginBottom="4dp"
            android:text="192.168.1.100:8080" android:textColor="#ccffffff" android:textSize="14sp" />

        <TextView android:id="@+id/controller_capabilities" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginStart="36dp"
            android:text="Capabilities: Recording, Sync, Data Collection" android:textColor="#aaffffff"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
