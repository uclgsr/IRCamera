# ===================================================================
# Recommended .gitignore for Android Projects
# ===================================================================

# IDE - Android Studio
# -------------------------------------------------------------------
# User-specific files
.idea/

# Generated files
*.iml
.cxx/
.externalNativeBuild/
/captures/


# Build
# -------------------------------------------------------------------
/build/
*/build/
**/build/
*.apk
*.aab
*.ap_
*.dex
*.class
*.hprof
*.snapshot
lint-results-*
lint-results*.html
lint-results*.xml
/build-cache/
**/build-cache/
*.war
#*.jar
.navigation/
captures/
.externalNativeBuild/
.cxx/
obj/


# Gradle
# -------------------------------------------------------------------
.gradle/
.build-cache/
buildSrc/build/
buildSrc/.gradle/
gradle-app.setting
.gradletasknamecache
gradle/wrapper/gradle-wrapper.jar

# Build artifacts and compiler cache that should not be committed
.kotlin/
*.log
build_*.log


# Local configuration
# -------------------------------------------------------------------
# Contains SDK path, API keys, and other user-specific information.
local.properties


# Signing files
# -------------------------------------------------------------------
# Keep these files private and out of version control.
*.jks
*.keystore


# OS-generated files
# -------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.tmp
*.temp

# IDE and cache files
# -------------------------------------------------------------------
# IntelliJ IDEA
.idea/shelf/
.idea/workspace.xml
.idea/tasks.xml
.idea/dictionaries/
.idea/vcs.xml
.idea/jsLibraryMappings.xml
.idea/datasources.xml
.idea/datasources/
.idea/sqlDataSources.xml
.idea/dynamic.xml
.idea/uiDesigner.xml
.idea/libraries/
.idea/gradle.xml
.idea/misc.xml
.idea/modules.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/deploymentTargetDropDown.xml
.idea/inspectionProfiles/
.idea/sonarlint/

# Android Studio cache
.android/
android.tests.runner/
.metadata/
.recommenders/
.gradle-wrapper/


# App/Project specific directories
# -------------------------------------------------------------------
# These are your custom rules, which are perfectly fine to keep.
/app/prod/
/app/prodTopdon/
/ai-upscale/
/ai-upscale/3rdparty/ncnn-android-vulkan-shared/armeabi-v7a/

# Python specific for PC controller
pc-controller/__pycache__/
pc-controller/**/__pycache__/
pc-controller/*.pyc
pc-controller/**/*.pyc
pc-controller/logs/
pc-controller/sessions/
pc-controller/.pytest_cache/
pc-controller/venv/
pc-controller/.env

# PC Controller specific additions
pc_recordings/
demo_recordings/
pc-controller/legacy_implementation/native_backend/build/
*.log

# Demos and tests cache files
demos/__pycache__/
tests/__pycache__/

# Python cache files - project-wide
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Backup files
*.backup
*.bak
*.orig
*~

# Documentation temporary and generated files
# -------------------------------------------------------------------
# Prevent accumulation of outdated documentation
docs/tmp/
docs/temp/
docs/backup/
docs/generated/
docs/*_backup_*/
docs/*_old_*/
docs/legacy/
docs/archive/

# Generated documentation artifacts
*.html
*.pdf
!docs/**/*.html  # Allow HTML docs if intentionally added
!docs/**/*.pdf   # Allow PDF docs if intentionally added

# Documentation tool artifacts
.markdownlint-cache
.vale/
vale-logs/
docs/.doctrees/
docs/_build/

# Temporary files from editors
*~
*.swp
*.swo
.#*
\#*#

# Documentation that should be consolidated into main docs
*README*.md       # Prevent scattered README files
!README.md        # Allow main README
!docs/README.md   # Allow docs index
!docs/*/README.md # Allow specific module READMEs if needed

# Analysis and status reports that become outdated
*_ANALYSIS_*.md
*_STATUS_*.md
*_REPORT_*.md
BUILD_*.md
GRADLE_*.md
*MIGRATION*.md

# LaTeX backup files
*.bak*
docs/latex/*.bak*

