# =============================================================================
# General & OS-Specific Files
# Ignore files generated by operating systems and common tools.
# =============================================================================
.DS_Store
.DS_Store?
.Spotlight-V100
.Trashes
._*
$RECYCLE.BIN/
Desktop.ini
Thumbs.db
ehthumbs.db

# =============================================================================
# IDE & Editor Configuration
# Ignore configuration files from IDEs like IntelliJ, Android Studio, and others.
# =============================================================================
.idea/
.metadata/
.recommenders/
*.iml

# Allow specific IDE files that are often shared in teams
!/.idea/vcs.xml
!/.idea/gradle.xml
!/.idea/misc.xml
!/.idea/modules.xml

# =============================================================================
# Build System & Dependencies
# Ignore files related to Gradle, build caches, and dependencies.
# =============================================================================
.gradle/
.gradle-wrapper/
.build-cache/
.kotlin/
gradle/wrapper/gradle-wrapper.jar
gradle-app.setting
.gradletasknamecache

# =============================================================================
# Build Artifacts & Outputs
# Ignore all build outputs, compiled code, and packages.
# =============================================================================
**/build/
**/build-cache/
dist/
obj/
*.a
*.aab
*.ap_
*.apk
*.app
*.class
*.dex
*.dll
*.dylib
*.lib
*.o
*.obj
*.out
*.so
*.war

# Android-specific build outputs
.cxx/
.externalNativeBuild/
.navigation/
lint-results-*
lint-results*.html
lint-results*.xml

# =============================================================================
# Python
# Ignore Python-related build artifacts, caches, and virtual environments.
# =============================================================================
**/__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info
*.egg-info/
.installed.cfg
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
venv/

# =============================================================================
# Logs, Backups & Temporary Files
# Ignore log files, temporary data, and backups.
# =============================================================================
*.bak
*.bak*
*.backup
*.hprof
*.log
*.orig
*.swo
*.swp
*.temp
*.tmp
*~
.#*
\#*#
backup/
*/backup/
build_*.log
vale-logs/

# =============================================================================
# Local Configuration & Secrets
# Ignore files containing local settings, credentials, or other sensitive data.
# =============================================================================
.env
*.jks
*.keystore
*.pem
*.key
*.crt
local.properties

# =============================================================================
# Documentation Artifacts
# Ignore generated documentation files.
# =============================================================================
docs/_build/
docs/.doctrees/
docs/archive/
docs/backup/
docs/generated/
docs/latex/*.bak*
docs/legacy/
docs/temp/
docs/tmp/
docs/*_backup_*/
docs/*_old_*/
.markdownlint-cache
.vale/

# Custom rules for project documentation files
*.html
*.pdf
!docs/**/*.html
!docs/**/*.pdf

# Custom rules for project status/report files
*README*.md
!README.md
!docs/README.md
!docs/*/README.md
!docs/ANTI_PATTERNS_README.md
*_ANALYSIS_*.md
*_REPORT_*.md
*_STATUS_*.md
BUILD_*.md
GRADLE_*.md
*MIGRATION*.md

# =============================================================================
# Project-Specific Ignores
# Ignore files and directories specific to this project's structure.
# =============================================================================
# Android
.android/
android.tests.runner/
/ai-upscale/
/app/prod/
/app/prodTopdon/
captures/

# Python Controller (`pc-controller`)
pc-controller/.env
pc-controller/.pytest_cache/
pc-controller/certificates/
pc-controller/data/
pc-controller/enhanced_native_backend/
pc-controller/exports/
pc-controller/legacy_implementation/native_backend/build/
pc-controller/logs/
pc-controller/native_backend/*.pyd
pc-controller/native_backend/*.so
pc-controller/native_backend/build/
pc-controller/pc_recordings/
pc-controller/sessions/
pc-controller/venv/
demo_recordings/
pc_recordings/

# Python Testing Suite (`testing-suite`)
testing-suite/.pytest_cache/
testing-suite/results/
testing-suite/temp/

# Thesis Evaluation Test Outputs
thesis_evaluation/**/*.csv
thesis_evaluation/**/*.json
thesis_evaluation/real_session_data/