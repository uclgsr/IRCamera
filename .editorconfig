# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Kotlin files
[*.{kt,kts}]
indent_size = 4
continuation_indent_size = 8
max_line_length = 120

# Java files
[*.java]
indent_size = 4
max_line_length = 120

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# JavaScript/TypeScript files
[*.{js,ts,jsx,tsx}]
indent_size = 2
max_line_length = 100

# XML files
[*.xml]
indent_size = 4

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Gradle files
[*.{gradle,gradle.kts}]
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 100

# Properties files
[*.properties]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2