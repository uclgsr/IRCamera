<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Thermal imaging menu -->
    <declare-styleable name="MenuSecondView">
        <attr name="deviceType" format="enum">
            <enum name="single_light" value="0" /> <!-- Single light -->
            <enum name="double_light" value="1" /> <!-- Dual light -->
            <enum name="lite" value="2" />         <!-- Lite -->
            <enum name="tc007" value="3" />        <!-- TC007 -->
            <enum name="gallery_edit" value="4" /> <!-- 2DEdit -->
        </attr>
    </declare-styleable>
</resources>